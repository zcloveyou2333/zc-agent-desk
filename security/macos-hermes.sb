;; macOS-only MVP confinement profile for Hermes developer tools.
;; This is deliberately not described as a production-grade sandbox.
(version 1)
(deny default)
(import "system.sb")

;; Permit the shell and ordinary runtime discovery.
(allow process*)
(allow sysctl-read)
(allow mach-lookup)
(allow file-read*)

;; Protect common user credential locations even though system files are
;; generally readable for Python, shells, dynamic libraries, and certificates.
(deny file-read* (subpath (string-append (param "USER_HOME") "/.ssh")))
(deny file-read* (subpath (string-append (param "USER_HOME") "/.gnupg")))
(deny file-read* (subpath (string-append (param "USER_HOME") "/.aws")))
(deny file-read* (subpath (string-append (param "USER_HOME") "/.config/gh")))

;; Writes are confined to the checked-out ZC Agent Desk workspace.
(allow file-write* (subpath (param "WORKSPACE")))

